{
int base,low_ram,high_ram,stack;
//proteção da memoria e checagem par evitar escrita se caso um enderços estiver sendo usado
 stack >= base && stack <(base  + high_ram);
    {
  stack < low_ram | stack < high_ram;
    // Pilha está dentro da RAM das threads
